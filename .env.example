# API Keys
OPENAI_API_KEY=sk-proj-your_openai_key_here
ANTHROPIC_API_KEY=sk-ant-api03-your_anthropic_key_here

# Database — PostgreSQL + pgvector
DATABASE_URL=postgresql://regulation_app:your_password_here@localhost:5432/regulation_rag

# Application
BASE_URL=http://localhost:8002
ENABLE_VERBATIM_QUOTES=true   # always true — federal regulations are public domain

# Generation strategy: "single" or "sequential"
LLM_CALL_STRATEGY=sequential

# RAG retrieval config — updated after Phase 2/5 evaluation
RAG_SOURCE_SYSTEM=federal_regulations
RAG_TOP_K=6

# Embedding
EMBEDDING_MODEL=text-embedding-3-small

# eCFR API
ECFR_API_BASE=https://www.ecfr.gov/api/versioner/v1

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8002
